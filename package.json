{
  "name": "pikemon",
  "version": "1.2.0",
  "description": "P2P Anonymous Chat - No server, no database",
  "main": "src/main.js",
  "scripts": {
    "postinstall": "node -e \"require('fs').copyFileSync('node_modules/peerjs/dist/peerjs.min.js', 'src/peerjs.min.js')\"",
    "copy-peerjs": "node -e \"require('fs').copyFileSync('node_modules/peerjs/dist/peerjs.min.js', 'src/peerjs.min.js')\"",
    "start": "npm run copy-peerjs && electron .",
    "build": "npm run copy-peerjs && electron-builder --win --x64",
    "build:portable": "npm run copy-peerjs && electron-builder --win portable --x64"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "peerjs": "^1.5.2",
    "electron-updater": "^6.1.7"
  },
  "build": {
    "appId": "com.pikemon.app",
    "productName": "Pikemon",
    "publish": {
      "provider": "github",
      "owner": "JustHonoris",
      "repo": "pikemon"
    },
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "Pikemon-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  }
}